{
  "name": "noviq",
  "private": true,
  "description": "Noviq AI — inference network powered by contributed compute",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev:website": "pnpm --filter noviq-website dev",
    "dev:data": "pnpm --filter noviq-data dev",
    "dev:client": "pnpm --filter @noviq/worker dev",
    "build:website": "pnpm --filter noviq-website build",
    "build:data": "pnpm --filter noviq-data build",
    "build:client": "pnpm --filter @noviq/worker build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@reown/appkit",
      "bufferutil",
      "esbuild",
      "keccak",
      "utf-8-validate"
    ]
  }
}
