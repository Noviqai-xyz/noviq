# Orchestrator config
# Copy to .env and fill in. NEVER commit .env.

# HTTP + WebSocket port
PORT=8787

# Supabase Postgres connection string.
# Use the "Connection pooling" (Transaction) string from Supabase → Project Settings → Database.
# Example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Privy (server-side token verification) - same app as the website.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Comma-separated list of browser origins allowed to call the HTTP API.
# e.g. https://noviqai.xyz,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: seconds between server pings to workers (default 30)
PING_INTERVAL_SEC=30

# Optional: minimum USD balance before a contributor can request a payout (default 10)
PAYOUT_THRESHOLD_USD=10

# Admin secret for provisioning seed-worker tokens (the noviq_workers bootstrap
# fleet). Leave blank to disable /v1/admin/* routes entirely. Use a long random value.
ADMIN_SECRET=

# --- Consumer billing (public inference API) ---
# Billing defaults ON in production and OFF otherwise, so localhost dev is free.
# Force it explicitly with true|false (leave blank to use the NODE_ENV default).
BILLING_ENABLED=
# Free API requests per user before credits (USDG / $NOVIQ) are required.
FREE_TIER_REQUESTS=5
# Fraction of each job's market price paid to the worker (rest is platform margin).
WORKER_REVENUE_SHARE=0.8
# Optional $NOVIQ emission reward per 1K tokens served (supply bootstrap). 0 = off.
EMISSION_NOVIQ_PER_1K=0
# Optional JSON override of the per-tier price table (USD per 1K tokens).
# Prices default to market rates in src/pricing.ts; retune live without a redeploy.
# e.g. {"small":{"inputPer1k":0.00008,"outputPer1k":0.0003},"large":{"outputPer1k":0.0025}}
PRICING_JSON=
