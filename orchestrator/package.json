  "devDependencies": {
    "@types/node": "^22",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
