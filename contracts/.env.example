# --- NoviqStaking deployment (EVM / Robinhood Chain) ---

# Deployer private key (no 0x prefix issues: forge accepts 0x-prefixed)
PRIVATE_KEY=0x...

# $NOVIQ ERC-20 address from the Robinhood launchpad
STAKE_TOKEN=0x...

# Reward token: USDC (real yield) or the same as STAKE_TOKEN for $NOVIQ rewards
REWARD_TOKEN=0x...

# Unstake cooldown in seconds (0 = instant, 86400 = 1 day, max 604800 = 7 days)
UNSTAKE_COOLDOWN=0

# Admin address (can only set cooldown / rescue non-core tokens; never user funds)
OWNER=0x...

# --- Network (fill from Robinhood Chain docs) ---
RPC_URL=https://<robinhood-chain-rpc>
CHAIN_ID=<robinhood-chain-id>
EXPLORER_API_URL=https://<explorer-api>
ETHERSCAN_API_KEY=<explorer-verify-key>
